# =============================================================================
# MetaboCoach Environment Variables
# =============================================================================

# --- App ---
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production

# --- Database (PostgreSQL + TimescaleDB) ---
DATABASE_URL=postgresql+asyncpg://metabocoach:password@localhost:5432/metabocoach
DATABASE_URL_SYNC=postgresql://metabocoach:password@localhost:5432/metabocoach

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Google Gemini AI ---
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash

# --- LibreLinkUp (FreeStyle Libre 2) ---
LIBRE_EMAIL=your-libreview-email
LIBRE_PASSWORD=your-libreview-password
LIBRE_REGION=us
# Region endpoints: us=api.libreview.io, eu=api-eu.libreview.io

# --- Garmin Connect ---
GARMIN_CONSUMER_KEY=your-garmin-consumer-key
GARMIN_CONSUMER_SECRET=your-garmin-consumer-secret

# --- Twilio (WhatsApp) ---
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# --- GCP (Google Cloud Platform) ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCS_BUCKET_NAME=metabocoach-photos

# --- Sentry ---
SENTRY_DSN=

# --- User Defaults ---
DEFAULT_TIMEZONE=America/Toronto
DEFAULT_GLUCOSE_LOW=3.9
DEFAULT_GLUCOSE_HIGH=10.0
